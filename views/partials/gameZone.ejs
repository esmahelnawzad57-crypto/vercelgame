<section class="container-fluid px-lg-4 d-none" id="gameZone">
    <div class="glass-panel py-2 mb-3" role="alert" style="border-radius: 16px;">
        <div class="row align-items-center mx-0">
            <div class="col-2 text-start">
                <p class="lead fw-bold mb-0 d-inline-block px-3 py-1 text-white shadow-sm" id="clock" style="background: rgba(255,0,0,0.6); border-radius: 10px; text-shadow: 0 0 5px rgba(255,0,0,0.8);">0</p>
            </div>
            <div class="col-10 col-md-8 text-center text-white" id="wordDiv">
                <p class="lead mb-0 text-white-50">چاوەڕوانی دەستپێکردن...</p>
            </div>
        </div>
    </div>
    <div class="row justify-content-center mx-0">
        <div class="col-3 col-lg-2 h-100 players px-1"></div>
        <div class="col-9 col-lg-7 h-100 d-flex flex-column pe-0 px-lg-3">
            <div id="sketchpad" class="text-center mb-2" style="background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 0 20px rgba(0,242,254,0.2);"></div>
            <%- include('tools') %>
        </div>
        <div class="col-12 col-lg-3 h-100 glass-panel p-2 mt-3 mt-lg-0 d-flex flex-column">
            <div class="messages flex-grow-1"></div>
            <form id="sendMessage" class="mt-2">
                <input class="form-control text-end" type="text" placeholder="پێشبینییەکەت لێرە بنووسە..." style="background: rgba(0,0,0,0.4) !important;">
                <div class="position-relative">
                    <ul class="list-group mt-1" id="suggestions"></ul>
                </div>
            </form>
        </div>
    </div>
</section>