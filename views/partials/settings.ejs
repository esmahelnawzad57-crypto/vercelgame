<section class="container d-none" id="settings">
    <div class="row justify-content-between mx-0 align-items-stretch">
        <div class="col-md-6 order-2 order-md-0 glass-panel p-4 mb-4 mb-md-0">
            <h2 class="text-center mb-4 fw-bold text-white">ڕێکخستنەکان</h2>
            <div class="input-group mb-3">
                <label class="input-group-text" for="rounds">خولەکان</label>
                <select class="form-select" id="rounds">
                    <option value="2" selected>2 خول</option>
                    <option value="3">3 خول</option>
                    <option value="4">4 خول</option>
                    <option value="5">5 خول</option>
                    <option value="6">6 خول</option>
                    <option value="7">7 خول</option>
                    <option value="8">8 خول</option>
                    <option value="9">9 خول</option>
                    <option value="10">10 خول</option>
                </select>
            </div>
            <div class="input-group mb-3">
                <label class="input-group-text" for="time">کاتی کێشان (بە چرکە)</label>
                <select class="form-select" id="time">
                    <option value="30">30 چرکە</option>
                    <option value="40" selected>40 چرکە</option>
                    <option value="50">50 چرکە</option>
                    <option value="60">60 چرکە</option>
                    <option value="70">70 چرکە</option>
                    <option value="80">80 چرکە</option>
                    <option value="90">90 چرکە</option>
                    <option value="100">100 چرکە</option>
                    <option value="110">110 چرکە</option>
                    <option value="120">120 چرکە</option>
                    <option value="130">130 چرکە</option>
                    <option value="140">140 چرکە</option>
                    <option value="150">150 چرکە</option>
                    <option value="160">160 چرکە</option>
                    <option value="170">170 چرکە</option>
                    <option value="180">180 چرکە</option>
                </select>
            </div>
            <% if(!roomID) { %>
            <div class="input-group mb-3">
                <label class="input-group-text" for="customWords">وشەی تایبەت</label>
                <textarea class="form-control" placeholder="وشەی1&#10;وشەی2&#10;وشەی3" id="customWords"
                    style="height: 15vh; resize:none; background: rgba(0,0,0,0.2) !important;"></textarea>
            </div>
            <div class="mb-4">
                <label for="probability" class="form-label text-white">ڕێژەی دەرکەوتنی وشە تایبەتەکان</label>
                <input type="range" class="form-range" min="0" max="1" step="0.01" id="probability">
            </div>
            <% } %>
            <button class="btn btn-primary w-100 py-2 fs-5 mt-2" id="startGame">دەستپێکردنی یاری</button>
        </div>
        <div class="col-md-5 text-white p-4 glass-panel">
            <h2 class="text-center mb-4 fw-bold">یاریزانەکان</h2>
            <div class="row mt-4 mx-0" style="height: 20em; overflow-y: auto;" id="playersDiv"></div>
        </div>
    </div>
    <div class="mt-4 glass-panel p-3 text-center w-75 mx-auto">
        <h3 class="text-white mb-3">هاوڕێکانت بانگهێشت بکە!</h3>
        <div class="input-group">
            <input type="text" id="gameLink" class="form-control text-center fw-bold bg-white text-dark"
                value="http://localhost:3000/" readonly style="background: rgba(255,255,255,0.8) !important;">
            <button class="btn btn-warning px-4 fw-bold" type="button" id="copy">کۆپیکردنی بەستەر</button>
        </div>
    </div>
</section>